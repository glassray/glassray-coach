{
  "name": "@glassray/coach",
  "version": "0.2.1",
  "description": "Glassray Coach — a fully self-contained local AI-agent trace debugger (OTLP in, dashboard + agent-first CLI out).",
  "keywords": [
    "ai-agents",
    "glassray",
    "observability",
    "opentelemetry",
    "otlp",
    "tracing",
    "llm",
    "evals",
    "debugger",
    "local"
  ],
  "type": "module",
  "license": "MIT",
  "author": "Glassray",
  "homepage": "https://github.com/glassray/glassray-coach#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glassray/glassray-coach.git"
  },
  "bugs": {
    "url": "https://github.com/glassray/glassray-coach/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.6"
  },
  "bin": {
    "glassray": "bin/glassray.mjs"
  },
  "files": [
    "bin",
    "server",
    "!server/**/*.test.ts",
    "skills",
    "web/dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:ui": "vite web",
    "build:ui": "vite build web",
    "start": "tsx server/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && npm run typecheck:web",
    "typecheck:web": "tsc -p web/tsconfig.json --noEmit",
    "test:egress": "node test/egress-proof.mjs",
    "prepack": "vite build web"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@electric-sql/pglite": "0.5.4",
    "@electric-sql/pglite-pgvector": "0.0.5",
    "@fastify/static": "^9.1.3",
    "ai": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.9.0",
    "tsx": "^4.22.5",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.152"
  },
  "devDependencies": {
    "@glassray/tracing": "^0.1.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
